<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /company-profile/

  # Keep direct file/folder requests untouched.
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Keep backend/API routes untouched (avoid SPA fallback conflicts).
  RewriteRule ^(web|api|uploads|health)(/|$) - [L]

  # SPA fallback for Company Profile routes.
  RewriteRule . index.html [L]
</IfModule>
